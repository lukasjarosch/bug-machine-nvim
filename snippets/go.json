{
  "type struct constructor": {
    "prefix": "tysc",
    "body": [
      "type ${1:Name} struct {",
      "\t$2",
      "}",
      "",
      "func ${1/^([a-z])?(.*)/${1:?new:New}${1:/upcase}$2/}($3) (*$1, error) {",
      "\treturn &$1{$4}, nil",
      "}",
      "$0"
    ],
    "description": "Go type with constructor"
  },
  "println": {
    "prefix": "prl",
    "body": [
      "fmt.Println(\"$1\")",
      "$0"
    ],
    "description": "fmt.Println"
  }
}
